# Copy to .env and fill in values
# Run: cp .env.example .env

# Turso DB (get from: turso db create movie-night && turso db show movie-night)
TURSO_URL=libsql://your-db-name.turso.io
TURSO_TOKEN=your-turso-token

# JWT signing secret — generate with: openssl rand -base64 32
JWT_SECRET=change-me-generate-a-strong-secret

# Invite codes — share MEMBER_INVITE_CODE with guests, ADMIN_INVITE_CODE only to yourself
MEMBER_INVITE_CODE=change-me-member-code
ADMIN_INVITE_CODE=change-me-admin-code

# CORS allowed origin — set to https://baphometbabes.com in production
# Leave as * for local dev
ALLOWED_ORIGIN=*

# Port (Cloud Run sets this automatically; leave as-is for local dev)
PORT=8080
