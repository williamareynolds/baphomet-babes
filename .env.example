# Copy to .env: cp .env.example .env
# Local Firestore auth: gcloud auth application-default login

# GCP project ID (same project as Cloud Run + Firestore)
GCP_PROJECT_ID=your-gcp-project-id

# JWT signing secret — generate: openssl rand -base64 32
JWT_SECRET=change-me-generate-a-strong-secret

# One-time superadmin bootstrap — share with no one except the first superadmin
# Permanently inactive after the first superadmin registers
SUPERADMIN_INVITE_CODE=change-me-superadmin-bootstrap

# CORS — * for local dev, set to https://movienight.baphometbabes.com in prod
ALLOWED_ORIGIN=*

# Port (Cloud Run sets this automatically)
PORT=8080
